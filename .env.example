# ==============================================================================
# CONFIGURAÇÃO DE AMBIENTE - GESTÃO DE FÉRIAS
# Renomeie para ".env" na raiz do projeto.
# ==============================================================================

# BANCO DE DADOS (PostgreSQL)
DB_USER=admin
DB_PASSWORD=adminpassword
DB_NAME=gestaoferias

# SEGURANÇA
# No local pode ser qualquer coisa, em PROD use uma string longa e aleatória.
JWT_SECRET=sua_chave_secreta_ultra_segura_para_producao_123

# URL DA API PARA O FRONTEND (Next.js)
# Em LOCAL: http://localhost:3000/api/v1
# Em PROD: https://api.seudominio.com
PUBLIC_API_URL=http://localhost:3000/api/v1

# NODE (Geralmente setado automaticamente pelo docker)
NODE_ENV=development
